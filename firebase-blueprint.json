{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (income or expense)",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "The date of the transaction" },
        "description": { "type": "string", "description": "A description of the transaction" },
        "category": { "type": "string", "description": "The category of the transaction" },
        "amount": { "type": "number", "description": "The amount of the transaction" },
        "type": { "type": "string", "enum": ["income", "expense"], "description": "The type of transaction" },
        "uid": { "type": "string", "description": "The user ID who owns this transaction" }
      },
      "required": ["date", "description", "category", "amount", "type", "uid"]
    },
    "Budget": {
      "title": "Budget",
      "description": "A monthly budget for a specific category",
      "type": "object",
      "properties": {
        "category": { "type": "string", "description": "The category for the budget" },
        "amount": { "type": "number", "description": "The budgeted amount" },
        "uid": { "type": "string", "description": "The user ID who owns this budget" }
      },
      "required": ["category", "amount", "uid"]
    },
    "User": {
      "title": "User",
      "description": "A user profile",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "The user's email" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role" }
      },
      "required": ["email", "displayName", "role"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A financial invoice (income or expense)",
      "type": "object",
      "properties": {
        "orderNo": { "type": "number", "description": "The order number" },
        "date": { "type": "string", "format": "date", "description": "The date of the invoice" },
        "firmName": { "type": "string", "description": "The firm name" },
        "type": { "type": "string", "enum": ["income", "expense"], "description": "The type of invoice" },
        "invoiceNo": { "type": "string", "description": "The invoice number" },
        "vatBase": { "type": "number", "description": "The VAT base amount" },
        "vatRate": { "type": "number", "description": "The VAT rate" },
        "vatAmount": { "type": "number", "description": "The VAT amount" },
        "totalAmount": { "type": "number", "description": "The total amount" },
        "uid": { "type": "string", "description": "The user ID who owns this invoice" }
      },
      "required": ["date", "firmName", "type", "invoiceNo", "vatBase", "vatRate", "vatAmount", "totalAmount", "uid"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A financial payment or collection",
      "type": "object",
      "properties": {
        "orderNo": { "type": "number", "description": "The order number" },
        "date": { "type": "string", "format": "date", "description": "The date of the payment" },
        "firmName": { "type": "string", "description": "The firm name" },
        "type": { "type": "string", "enum": ["collection", "payment"], "description": "The type of payment" },
        "paymentMethod": { "type": "string", "description": "The payment method" },
        "amount": { "type": "number", "description": "The amount" },
        "uid": { "type": "string", "description": "The user ID who owns this payment" }
      },
      "required": ["date", "firmName", "type", "paymentMethod", "amount", "uid"]
    }
  },
  "firestore": {
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Collection of financial transactions"
    },
    "/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "Collection of user budgets"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Collection of invoices"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Collection of payments"
    },
    "/test/{testId}": {
      "schema": "object",
      "description": "Connection test collection"
    }
  }
}
